# AI App Builder Engine - Environment Variables
# =============================================================================
# REQUIRED - Core AI Providers
# =============================================================================

# OpenAI API Key (fallback paid provider)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview

# OpenRouter API Key (free models via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Groq API Key (free fast models)
GROQ_API_KEY=gsk_your-groq-key

# Google Gemini API Key (free models)
GEMINI_API_KEY=AIza-your-gemini-key

# =============================================================================
# DATABASE - Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# AUTHENTICATION - Clerk
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# =============================================================================
# PAYMENTS - Stripe
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# =============================================================================
# DEPLOYMENT - Vercel
# =============================================================================
VERCEL_TOKEN=your-vercel-token

# =============================================================================
# STORAGE - GitHub (for Git integration)
# =============================================================================
GITHUB_TOKEN=ghp_your-github-token

# =============================================================================
# OPTIONAL - Advanced Features
# =============================================================================

# WebContainer API (for in-browser backend execution)
WEBCONTAINER_API_KEY=your-webcontainer-key

# Real-time collaboration (WebRTC signaling)
WEBRTC_SIGNALING_URL=wss://your-signaling-server.com

# Rate limiting (requests per minute)
MAX_AI_REQUESTS_PER_MINUTE=30

# Feature flags
ENABLE_AI_AGENTS=true
ENABLE_MULTI_PROVIDER=true
ENABLE_REALTIME_COLLAB=true
ENABLE_WEBCONTAINER=true
